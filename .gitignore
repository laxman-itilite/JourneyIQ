# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
*.pyd

# Distribution / packaging
build/
dist/
wheels/
*.egg-info/
*.egg
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# uv
.python-version          # machine-specific; don't force Python version on others
uv.lock                  # commit this if you want reproducible installs, remove line if so

# ── Environment / secrets ─────────────────────────────────────────────────────
.env                     # ANTHROPIC_API_KEY and other secrets — never commit
.env.*                   # .env.local, .env.production, etc.
!.env.example            # keep the example template in git

# ── IDE / editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyright/
.ruff_cache/
